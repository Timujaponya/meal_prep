# Railway PostgreSQL baglanti adresi
DATABASE_URL=postgresql://user:password@host:port/database

# Zorunlu: auth token imzalama anahtari (en az 32 karakter)
AUTH_SECRET=replace_with_a_long_random_secret_value

# Opsiyonel: TLS gerekiyorsa
# PGSSLMODE=require

# USDA import scripti icin API anahtari
# USDA_API_KEY=your_api_key

# Opsiyonel: import hedef kayit adedi (varsayilan 500)
# USDA_TARGET_COUNT=500

# Opsiyonel: import cikti dosya yolu
# USDA_OUTPUT_PATH=/absolute/path/to/server/src/data/catalog/foods.usda.json

# Opsiyonel: server seed katalog dosya yolu
# FOOD_CATALOG_PATH=/absolute/path/to/server/src/data/catalog/foods.curated.json

# Opsiyonel: startup seed modu
# insert-missing: sadece eksik id'leri ekler (varsayilan)
# full-sync: katalogu upsert eder, prune aciksa ekstra id'leri siler
# FOOD_SEED_MODE=insert-missing

# Opsiyonel: FOOD_SEED_MODE=full-sync iken katalogda olmayan foods kayitlarini sil
# FOODS_PRUNE_UNKNOWN=false
